# =====================================================
# DeployFast Task Manager - Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs
# NE JAMAIS COMMITTER le fichier .env réel !
# =====================================================

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/taskmanager
POSTGRES_DB=taskmanager
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (générer une clé base64 sécurisée)
# Commande: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET_KEY
JWT_EXPIRATION=86400000

# Application
PORT=8080
DDL_AUTO=update

# DockerHub (pour le pipeline CI/CD)
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token

# SonarCloud
SONAR_TOKEN=your_sonarcloud_token
SONAR_PROJECT_KEY=deployfast_taskmanager
SONAR_ORGANIZATION=deployfast

# Serveur de déploiement
DEPLOY_HOST=your.server.ip
DEPLOY_USER=ubuntu
# DEPLOY_SSH_KEY: clé SSH privée (à configurer dans GitHub Secrets)
